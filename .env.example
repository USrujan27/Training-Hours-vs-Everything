# ─────────────────────────────────────────────────────────────
# AIvsHire — Environment Variables Template
# Copy this file to .env and fill in your real values locally.
# NEVER commit .env to GitHub — it is listed in .gitignore.
# On Replit, set these in the Secrets tab instead.
# ─────────────────────────────────────────────────────────────

# ── AI / LLM ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Firebase (Auth) ───────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Your apps
GOOGLE_API_KEY=AIza...
GOOGLE_CLIENT_ID=171312393255-....apps.googleusercontent.com

# ── Kaggle (Dataset fetch) ────────────────────────────────────
# Get from kaggle.com → Account → API → Create New Token
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=KGAT_...
