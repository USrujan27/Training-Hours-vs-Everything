modules = ["python-3.12"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["glibcLocales", "libxcrypt"]

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 5173
externalPort = 80

[[ports]]
localPort = 5174
externalPort = 3000
exposeLocalhost = true

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8099
externalPort = 8099
